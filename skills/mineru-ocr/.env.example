# MinerU Token 配置示例
# 复制为 .env 并填入真实值,或直接放到矿师傅指定位置。

# 必填:MinerU API Token(JWT,API 管理页自定创建)
# https://mineru.net/apiManage
MINERU_TOKEN=

# 可选:Token 文件路径(优先级低于环境变量)
# 默认读取 ~/Desktop/mineru.txt
# MINERU_TOKEN_FILE=D:\secrets\mineru_token.txt

# 可选:默认模型版本
# 可选值:vlm(推荐,精度高) | pipeline(快) | MinerU-HTML(仅 HTML)
# MINERU_MODEL_VERSION=vlm

# 可选:默认文档语言
# 常用:ch(中英)/ ch_server(含繁体手写)/ en(纯英文)
# MINERU_LANGUAGE=ch

# 可选:扫描件 OCR(中文扫描件务必打开)
# MINERU_IS_OCR=false
